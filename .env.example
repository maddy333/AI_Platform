# AI Platform configuration (Twelve-Factor: config from the environment).
# Copy to .env for local development. Deployed environments must inject real
# environment variables; never commit a populated .env file.
#
# Nested settings use "__" as the delimiter: AIP_<SECTION>__<FIELD>=<value>

# --- Application ---
AIP_ENVIRONMENT=development          # development | test | staging | production
AIP_DEBUG=false

# --- Server ---
AIP_SERVER__HOST=0.0.0.0
AIP_SERVER__PORT=8000
AIP_SERVER__WORKERS=1

# --- Logging ---
AIP_LOGGING__LEVEL=INFO              # DEBUG | INFO | WARNING | ERROR | CRITICAL
AIP_LOGGING__FORMAT=console          # json (production) | console (development)

# --- Telemetry ---
AIP_TELEMETRY__ENABLED=false
AIP_TELEMETRY__OTLP_ENDPOINT=http://localhost:4318
AIP_TELEMETRY__SAMPLE_RATIO=1.0

# --- CORS (JSON array syntax; empty list disables CORS) ---
# AIP_CORS__ALLOW_ORIGINS=["https://admin.example.com"]

# =============================================================================
# AI Gateway (Milestone 2)
# =============================================================================
# Each provider is disabled by default. Set enabled=true and supply an API key
# (or base URL for self-hosted providers) to activate it.

# --- OpenAI ---
AIP_GATEWAY__OPENAI__ENABLED=false
# AIP_GATEWAY__OPENAI__API_KEY=sk-...
# AIP_GATEWAY__OPENAI__TIMEOUT=60
# AIP_GATEWAY__OPENAI__MAX_RETRIES=3

# --- Anthropic ---
AIP_GATEWAY__ANTHROPIC__ENABLED=false
# AIP_GATEWAY__ANTHROPIC__API_KEY=sk-ant-...
# AIP_GATEWAY__ANTHROPIC__TIMEOUT=120

# --- Google Gemini ---
AIP_GATEWAY__GEMINI__ENABLED=false
# AIP_GATEWAY__GEMINI__API_KEY=AIza...

# --- Azure OpenAI ---
AIP_GATEWAY__AZURE_OPENAI__ENABLED=false
# AIP_GATEWAY__AZURE_OPENAI__API_KEY=...
# AIP_GATEWAY__AZURE_OPENAI__AZURE_ENDPOINT=https://<resource>.openai.azure.com
# AIP_GATEWAY__AZURE_OPENAI__AZURE_DEPLOYMENT=gpt-4o
# AIP_GATEWAY__AZURE_OPENAI__API_VERSION=2024-12-01-preview

# --- Ollama (self-hosted) ---
AIP_GATEWAY__OLLAMA__ENABLED=false
# AIP_GATEWAY__OLLAMA__BASE_URL=http://localhost:11434

# --- vLLM (self-hosted OpenAI-compatible) ---
AIP_GATEWAY__VLLM__ENABLED=false
# AIP_GATEWAY__VLLM__BASE_URL=http://localhost:8001/v1
# AIP_GATEWAY__VLLM__API_KEY=token-...

# --- OpenRouter ---
AIP_GATEWAY__OPENROUTER__ENABLED=false
# AIP_GATEWAY__OPENROUTER__API_KEY=sk-or-...
# AIP_GATEWAY__OPENROUTER__HTTP_REFERER=https://your-app.example.com
# AIP_GATEWAY__OPENROUTER__X_TITLE=AI Platform

# --- Circuit breaker defaults (overridable per provider) ---
# AIP_GATEWAY__DEFAULT_CIRCUIT_BREAKER__FAILURE_THRESHOLD=5
# AIP_GATEWAY__DEFAULT_CIRCUIT_BREAKER__RECOVERY_TIMEOUT=60
# AIP_GATEWAY__DEFAULT_CIRCUIT_BREAKER__HALF_OPEN_MAX=2

# =============================================================================
# Intelligent Model Router (Milestone 3)
# =============================================================================
# The router selects the optimal (provider, model) pair for every request using
# a pluggable scoring strategy. It is layered on top of the Gateway: disable it
# to fall back to simple registry-order failover.

# --- Router core ---
AIP_ROUTER__ENABLED=true
# AIP_ROUTER__DEFAULT_STRATEGY=balanced   # cost | latency | quality | balanced

# --- Balanced strategy weights (must sum to a positive number; auto-normalised) ---
# AIP_ROUTER__COST_WEIGHT=0.35
# AIP_ROUTER__LATENCY_WEIGHT=0.35
# AIP_ROUTER__QUALITY_WEIGHT=0.30

# --- EWMA latency tracker ---
# Alpha controls how quickly the moving average reacts to new observations.
# 0 < alpha <= 1; lower = smoother, higher = more reactive.
# AIP_ROUTER__LATENCY_ALPHA=0.2

# --- Cost estimation ---
# Default output token count used when max_tokens is not specified in the request.
# AIP_ROUTER__DEFAULT_OUTPUT_TOKENS=512

# Virtual model aliases — no environment variables needed; resolved at runtime:
#   smart    → QUALITY strategy  (best reasoning/accuracy)
#   fast     → LATENCY strategy  (lowest measured p50 latency)
#   cheap    → COST strategy     (lowest estimated USD cost)
#   balanced → BALANCED strategy (weighted cost + latency + quality)
