# AI Platform configuration (Twelve-Factor: config from the environment).
# Copy to .env for local development. Deployed environments must inject real
# environment variables; never commit a populated .env file.
#
# Nested settings use "__" as the delimiter: AIP_<SECTION>__<FIELD>=<value>

# --- Application ---
AIP_ENVIRONMENT=development          # development | test | staging | production
AIP_DEBUG=false

# --- Server ---
AIP_SERVER__HOST=0.0.0.0
AIP_SERVER__PORT=8000
AIP_SERVER__WORKERS=1

# --- Logging ---
AIP_LOGGING__LEVEL=INFO              # DEBUG | INFO | WARNING | ERROR | CRITICAL
AIP_LOGGING__FORMAT=console          # json (production) | console (development)

# --- Telemetry ---
AIP_TELEMETRY__ENABLED=false
AIP_TELEMETRY__OTLP_ENDPOINT=http://localhost:4318
AIP_TELEMETRY__SAMPLE_RATIO=1.0

# --- CORS (JSON array syntax; empty list disables CORS) ---
# AIP_CORS__ALLOW_ORIGINS=["https://admin.example.com"]
